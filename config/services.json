{
  "services": [
    {
      "name": "HexStrike MCP",
      "id": "hexstrike",
      "port": 3001,
      "type": "mcp",
      "healthPath": "/health",
      "description": "150+ security tools (nmap, nuclei, sqlmap, etc.)",
      "required": true
    },
    {
      "name": "Backend API",
      "id": "backend",
      "port": 8080,
      "type": "api",
      "healthPath": "/api/v1/health",
      "description": "Main Harbinger API server",
      "required": true
    },
    {
      "name": "MCP-UI",
      "id": "mcp-ui",
      "port": 3003,
      "type": "ui",
      "healthPath": "/health",
      "description": "Tool visualization and execution UI",
      "required": false
    },
    {
      "name": "RedTeam Ops",
      "id": "redteam",
      "port": 3004,
      "type": "api",
      "healthPath": "/api/health",
      "description": "C2 management, SOCKS, playbooks, Neo4j analysis",
      "required": false
    },
    {
      "name": "PentAGI",
      "id": "pentagi",
      "port": 3002,
      "type": "agent",
      "healthPath": "/health",
      "description": "Autonomous penetration testing agent",
      "required": false
    }
  ],
  "frontend": {
    "port": 3000,
    "apiProxy": "/api",
    "wsProxy": "/ws"
  },
  "proxyPaths": {
    "/api": "http://backend:8080",
    "/ws": "http://backend:8080",
    "/mcp/hexstrike": "http://hexstrike:3001",
    "/mcp/pentagi": "http://pentagi:3002",
    "/mcp/ui": "http://mcp-ui:3003",
    "/api/redteam": "http://redteam:3004"
  }
}
