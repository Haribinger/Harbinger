}

# ── DOCKER COMPOSE HELPER ──────────────────────────────────────────────────
dc() {
  cd "$HARBINGER_DIR"
  if docker compose version &>/dev/null; then
    docker compose "$@"
  elif command -v docker-compose &>/dev/null; then
    docker-compose "$@"
  else
    err "Docker Compose not found."
    return 1
  fi
}

# ── CHECK BUILD CONTEXT EXISTS ──────────────────────────────────────────────
# Returns list of services whose build context directories actually exist.
get_valid_services() {
  local valid=()
  local all_build_services=("backend" "frontend" "pentagi" "redteam" "hexstrike" "mcp-ui")
  local contexts=("./backend" "./frontend" "./mcp-plugins/pentagi" "./mcp-plugins/redteam" "./mcp-plugins/hexstrike-ai" "./mcp-plugins/mcp-ui")

  for i in "${!all_build_services[@]}"; do
    local ctx="${contexts[$i]}"
    if [ -d "$HARBINGER_DIR/${ctx#./}" ]; then
      valid+=("${all_build_services[$i]}")
    fi
  done
  echo "${valid[@]}"
}

get_missing_services() {
  local missing=()
  local all_build_services=("backend" "frontend" "pentagi" "redteam" "hexstrike" "mcp-ui")
  local contexts=("./backend" "./frontend" "./mcp-plugins/pentagi" "./mcp-plugins/redteam" "./mcp-plugins/hexstrike-ai" "./mcp-plugins/mcp-ui")

  for i in "${!all_build_services[@]}"; do
    local ctx="${contexts[$i]}"
    if [ ! -d "$HARBINGER_DIR/${ctx#./}" ]; then
      missing+=("${all_build_services[$i]}")
    fi
  done
  echo "${missing[@]}"
}

# ── INTERACTIVE WIZARD ──────────────────────────────────────────────────────
wizard() {
  banner

  local options=(
    "Update & Pull Latest"
    "Start Services"
    "Stop Services"
    "Restart Services"
    "Dev Mode (Frontend)"
    "View Logs"
    "Health Check / Doctor"
    "Initialize Project"
    "Full Rebuild"
    "Nuke & Reset"
  )
  local commands=("update" "start" "stop" "restart" "dev" "logs" "doctor" "init" "rebuild" "nuke")
  local selected=0
  local count=${#options[@]}

  # Hide cursor
  tput civis 2>/dev/null || true

  # Restore cursor on exit
  trap 'tput cnorm 2>/dev/null; exit' INT TERM EXIT

  while true; do
    # Print menu
    echo -e "  ${CYAN}┌${NC} ${BOLD}Harbinger Command Center${NC}"
    echo -e "  ${CYAN}│${NC}"
    echo -e "  ${CYAN}◆${NC} ${BOLD}What would you like to do?${NC}"

    for i in "${!options[@]}"; do
      if [ "$i" -eq "$selected" ]; then
        echo -e "  ${CYAN}│${NC}  ${CYAN}●${NC}  ${BOLD}${options[$i]}${NC}"
      else
        echo -e "  ${CYAN}│${NC}  ${DIM}○${NC}  ${DIM}${options[$i]}${NC}"
      fi
    done

    echo -e "  ${CYAN}└${NC}"
    echo ""
    echo -e "  ${DIM}↑/↓ navigate  ·  Enter select  ·  q quit${NC}"

    # Read key
    local key
    IFS= read -rsn1 key

    case "$key" in
      $'\x1b')
        read -rsn2 -t 0.1 key
        case "$key" in
          '[A') selected=$(( (selected - 1 + count) % count )) ;;
          '[B') selected=$(( (selected + 1) % count )) ;;
        esac
        ;;
      'k') selected=$(( (selected - 1 + count) % count )) ;;
      'j') selected=$(( (selected + 1) % count )) ;;
      '')
        # Enter pressed — restore cursor and run command
        tput cnorm 2>/dev/null || true
        trap - INT TERM EXIT
        echo ""
        run_command "${commands[$selected]}"
        return
        ;;
      'q'|'Q')
        tput cnorm 2>/dev/null || true
        trap - INT TERM EXIT
        echo ""
        info "Goodbye."
        return
        ;;
    esac

    # Move cursor up to redraw menu
    local lines=$(( count + 6 ))
    printf "\033[%dA\033[J" "$lines"
  done
}

# ── UPDATE ──────────────────────────────────────────────────────────────────
cmd_update() {
  banner
  timer_start
  phase_start "Updating Harbinger"

  # 1. Git pull
  spinner_start "Pulling latest from main..."
  cd "$HARBINGER_DIR"
  git fetch origin main 2>/dev/null || true
  spinner_stop

  LOCAL=$(git rev-parse HEAD 2>/dev/null || echo "unknown")
  REMOTE=$(git rev-parse origin/main 2>/dev/null || echo "unknown")

  if [ "$LOCAL" = "$REMOTE" ]; then
    step_ok "Already up to date"
  else
    BEHIND=$(git rev-list --count HEAD..origin/main 2>/dev/null || echo "?")
    spinner_start "Pulling $BEHIND new commit(s)..."
    git pull origin main --ff-only 2>/dev/null || git pull origin main --rebase 2>/dev/null || true
    spinner_stop
    step_ok "Pulled latest from main (${BEHIND} new commits)"
  fi

  # 2. Frontend dependencies
  if [ -f "$FRONTEND_DIR/package.json" ]; then
    spinner_start "Installing frontend dependencies..."
    cd "$FRONTEND_DIR"
    local dep_start
    dep_start=$(date +%s)
    if command -v pnpm &>/dev/null; then
      pnpm install --frozen-lockfile 2>/dev/null || pnpm install 2>/dev/null || true
    elif command -v npm &>/dev/null; then
      npm install 2>/dev/null || true
    fi
    local dep_end
    dep_end=$(date +%s)
    local dep_time=$(( dep_end - dep_start ))
    spinner_stop
    step_ok "Dependencies installed (${dep_time}s)"
  else
    step_warn "No frontend package.json found — skipping"
  fi

  # 3. Quick health check
  cd "$HARBINGER_DIR"
  if command -v docker &>/dev/null && dc ps 2>/dev/null | grep -q "Up"; then
    step_ok "Docker services running"
  else
    step_info "Docker services not running — use ${BOLD}start${NC} to launch"
  fi

  phase_end

  info "Next steps:"
  echo -e "    ${DIM}→ ./harbinger restart    Restart all Docker services${NC}"
  echo -e "    ${DIM}→ ./harbinger dev        Start frontend dev server${NC}"
  echo -e "    ${DIM}→ ./harbinger status     Check service health${NC}"
  echo ""
}

# ── STATUS ──────────────────────────────────────────────────────────────────
cmd_status() {
  banner
  timer_start
  phase_start "Harbinger Service Status"

  cd "$HARBINGER_DIR"

  # Git info
  local branch
  branch=$(git branch --show-current 2>/dev/null || echo "unknown")
  local commit
  commit=$(git log --oneline -1 2>/dev/null || echo "unknown")
  step_ok "Branch: ${BOLD}${branch}${NC}  ${DIM}(${commit})${NC}"

  # Docker services
  if command -v docker &>/dev/null; then
    echo -e "  ${DIM}│${NC}"

    local services=("postgres:5432" "redis:6379" "neo4j:7474" "backend:8080" "frontend:3000" "hexstrike:3001" "pentagi:3002" "mcp-ui:3003" "redteam:3004")
    for svc_port in "${services[@]}"; do
      local svc="${svc_port%%:*}"
      local port="${svc_port##*:}"
      if dc ps "$svc" 2>/dev/null | grep -q "Up"; then
        step_ok "${svc}: ${GREEN}RUNNING${NC} on port ${port}"
      elif dc ps "$svc" 2>/dev/null | grep -qi "restart"; then
        step_err "${svc}: ${RED}RESTARTING${NC} — check logs"
      else
        step_run "${svc}: ${DIM}not running${NC}"
      fi
    done
  else
    step_warn "Docker not found"
  fi

  phase_end
}

# ── START ───────────────────────────────────────────────────────────────────
cmd_start() {
  banner
  timer_start
  phase_start "Starting Harbinger Services"

  cd "$HARBINGER_DIR"
  spinner_start "Launching Docker services..."
  dc up -d 2>/dev/null
  spinner_stop
  step_ok "All services started"

  phase_end

  cmd_status
}

# ── STOP ────────────────────────────────────────────────────────────────────
cmd_stop() {
  banner
  timer_start
  phase_start "Stopping Harbinger Services"

  cd "$HARBINGER_DIR"
  spinner_start "Stopping Docker services..."
  dc down 2>/dev/null
  spinner_stop
  step_ok "All services stopped"

  phase_end
}

# ── RESTART (smart — skips services with missing build contexts) ────────────
cmd_restart() {
  banner
  timer_start
  phase_start "Restarting Harbinger Services"

  cd "$HARBINGER_DIR"

  # Check for missing build contexts
  local missing
  missing=$(get_missing_services)
  if [ -n "$missing" ]; then
    step_warn "Missing build contexts: ${YELLOW}${missing}${NC} — these will be skipped"
  fi

  spinner_start "Stopping services..."
  dc down 2>/dev/null
  spinner_stop
  step_ok "Services stopped"

  spinner_start "Starting services..."
  dc up -d 2>/dev/null
  spinner_stop
  step_ok "Services started"

  # Wait a moment for health checks
  spinner_start "Waiting for health checks..."
  sleep 4
  spinner_stop

  # Verify
  local healthy=0
  local total=0
  for svc in postgres redis neo4j backend; do
    total=$((total + 1))
    if dc ps "$svc" 2>/dev/null | grep -q "Up"; then
      healthy=$((healthy + 1))
    fi
  done

  if [ "$healthy" -eq "$total" ]; then
    step_ok "All core services healthy (${healthy}/${total})"
  else
    step_warn "Some services may still be starting (${healthy}/${total} healthy)"
  fi

  phase_end
}

# ── DEV MODE ────────────────────────────────────────────────────────────────
cmd_dev() {
  banner
  timer_start
  phase_start "Starting Frontend Dev Server"

  if [ ! -d "$FRONTEND_DIR" ]; then
    step_err "Frontend directory not found at ${FRONTEND_DIR}"
    phase_end
    return 1
  fi

  cd "$FRONTEND_DIR"

  if [ ! -d "node_modules" ]; then
    spinner_start "Installing dependencies first..."
    if command -v pnpm &>/dev/null; then
      pnpm install 2>/dev/null || true
    elif command -v npm &>/dev/null; then
      npm install 2>/dev/null || true
    fi
    spinner_stop
    step_ok "Dependencies installed"
  fi

  step_ok "Launching Vite dev server on ${CYAN}http://localhost:3000${NC}"
  echo -e "  ${DIM}│${NC}"
  echo -e "  ${DIM}└${NC} ${DIM}Press Ctrl+C to stop${NC}"
  echo ""

  if command -v pnpm &>/dev/null; then
    pnpm dev
  elif command -v npm &>/dev/null; then
    npm run dev
  else
    err "No package manager found."
    exit 1
  fi
}

# ── LOGS ────────────────────────────────────────────────────────────────────
cmd_logs() {
  local service="${1:-}"
  cd "$HARBINGER_DIR"

  if [ -n "$service" ]; then
    banner
    info "Streaming logs for ${BOLD}${service}${NC}  ${DIM}(Ctrl+C to stop)${NC}"
    echo ""
    dc logs -f --tail=100 "$service" 2>/dev/null
  else
    banner
    info "Streaming all service logs  ${DIM}(Ctrl+C to stop)${NC}"
    echo ""
    dc logs -f --tail=50 2>/dev/null
  fi
}

# ── REBUILD ─────────────────────────────────────────────────────────────────
cmd_rebuild() {
  banner
  timer_start
  phase_start "Full Rebuild"

  cd "$HARBINGER_DIR"

  # Pull
  spinner_start "Pulling latest code..."
  git pull origin main --ff-only 2>/dev/null || git pull origin main --rebase 2>/dev/null || true
  spinner_stop
  step_ok "Code updated"

  # Build
  spinner_start "Rebuilding Docker images (this may take a while)..."
  dc build --no-cache 2>/dev/null
  spinner_stop
  step_ok "Docker images rebuilt"

  # Restart
  spinner_start "Restarting services..."
  dc down 2>/dev/null
  dc up -d 2>/dev/null
  spinner_stop
  step_ok "Services restarted"

  # Frontend deps
  if [ -f "$FRONTEND_DIR/package.json" ]; then
    spinner_start "Installing frontend dependencies..."
    cd "$FRONTEND_DIR"
    if command -v pnpm &>/dev/null; then
      pnpm install 2>/dev/null || true
    elif command -v npm &>/dev/null; then
      npm install 2>/dev/null || true
    fi
    spinner_stop
    step_ok "Frontend dependencies installed"
  fi

  phase_end
}

# ── DOCTOR ──────────────────────────────────────────────────────────────────
cmd_doctor() {
  banner
  timer_start
  phase_start "Running Diagnostics"

  local issues=0

  # Prerequisites
  echo -e "  ${DIM}│${NC}  ${ITALIC}Prerequisites${NC}"
  if command -v git &>/dev/null; then
    step_ok "git: $(git --version 2>/dev/null | head -c 30)"
  else
    step_err "git: NOT FOUND"
    issues=$((issues + 1))
  fi

  if command -v docker &>/dev/null; then
    step_ok "docker: $(docker --version 2>/dev/null | head -c 40)"
  else
    step_err "docker: NOT FOUND"
    issues=$((issues + 1))
  fi

  if command -v node &>/dev/null; then
    step_ok "node: $(node --version 2>/dev/null)"
  else
    step_err "node: NOT FOUND"
    issues=$((issues + 1))
  fi

  if command -v pnpm &>/dev/null; then
    step_ok "pnpm: $(pnpm --version 2>/dev/null)"
  elif command -v npm &>/dev/null; then
    step_warn "pnpm: not found (using npm $(npm --version 2>/dev/null) as fallback)"
  else
    step_err "No package manager found"
    issues=$((issues + 1))
  fi

  echo -e "  ${DIM}│${NC}"

  # Environment
  echo -e "  ${DIM}│${NC}  ${ITALIC}Environment${NC}"
  if [ -f "$HARBINGER_DIR/.env" ]; then
    step_ok ".env file exists"
  elif [ -f "$HARBINGER_DIR/.env.example" ]; then
    step_warn ".env missing — run ${BOLD}./harbinger init${NC} to create it"
    issues=$((issues + 1))
  else
    step_err ".env missing and no .env.example found"
    issues=$((issues + 1))
  fi

  echo -e "  ${DIM}│${NC}"

  # Build contexts
  echo -e "  ${DIM}│${NC}  ${ITALIC}Build Contexts${NC}"
  local dirs=("backend" "harbinger-tools/frontend" "mcp-plugins/pentagi" "mcp-plugins/redteam" "mcp-plugins/hexstrike-ai" "mcp-plugins/mcp-ui")
  local labels=("Backend" "Frontend" "PentAGI" "Red Team" "HexStrike AI" "MCP-UI")
  for i in "${!dirs[@]}"; do
    if [ -d "$HARBINGER_DIR/${dirs[$i]}" ]; then
      step_ok "${labels[$i]}: ${DIM}${dirs[$i]}/${NC}"
    else
      step_err "${labels[$i]}: ${RED}MISSING${NC} — ${dirs[$i]}/"
      issues=$((issues + 1))
    fi
  done

  echo -e "  ${DIM}│${NC}"

  # Docker services
  echo -e "  ${DIM}│${NC}  ${ITALIC}Docker Services${NC}"
  cd "$HARBINGER_DIR"
  for svc in postgres redis neo4j; do
    if command -v docker &>/dev/null && dc ps "$svc" 2>/dev/null | grep -q "Up"; then
      step_ok "$svc: healthy"
    elif command -v docker &>/dev/null && dc ps "$svc" 2>/dev/null | grep -qi "restart"; then
      step_err "$svc: RESTARTING — run: ./harbinger logs $svc"
      issues=$((issues + 1))
    else
      step_run "$svc: ${DIM}not running${NC}"
    fi
  done

  echo -e "  ${DIM}│${NC}"

  # Frontend
  echo -e "  ${DIM}│${NC}  ${ITALIC}Frontend${NC}"
  if [ -d "$FRONTEND_DIR/node_modules" ]; then
    step_ok "node_modules exists"
  else
    step_warn "node_modules missing — run: ./harbinger update"
    issues=$((issues + 1))
  fi

  if [ -f "$FRONTEND_DIR/src/store/secretsStore.ts" ]; then
    step_ok "secretsStore.ts exists"
  else
    step_err "secretsStore.ts MISSING — this will cause a white screen!"
    issues=$((issues + 1))
  fi

  echo -e "  ${DIM}│${NC}"

  # Postgres init.sql
  echo -e "  ${DIM}│${NC}  ${ITALIC}Database${NC}"
  if [ -f "$HARBINGER_DIR/docker/postgres/init.sql" ]; then
    step_ok "docker/postgres/init.sql exists"
  else
    step_err "docker/postgres/init.sql MISSING — Postgres will restart-loop!"
    issues=$((issues + 1))
  fi

  echo -e "  ${DIM}│${NC}"

  if [ "$issues" -eq 0 ]; then
    step_ok "${GREEN}${BOLD}All checks passed! Harbinger is healthy.${NC}"
  else
    step_warn "${YELLOW}Found ${issues} issue(s). Fix them and run ./harbinger doctor again.${NC}"
  fi

  phase_end
}

# ── INIT ────────────────────────────────────────────────────────────────────
cmd_init() {
  banner
  timer_start
  phase_start "Initializing Harbinger"

  cd "$HARBINGER_DIR"

  # 1. .env
  if [ -f ".env" ]; then
    step_ok ".env already exists"
  elif [ -f ".env.example" ]; then
    cp .env.example .env
    step_ok "Created .env from .env.example"
    step_warn "Edit .env with your API keys and secrets"
  else
    step_err "No .env.example found — cannot create .env"
  fi

  # 2. Frontend deps
  if [ -f "$FRONTEND_DIR/package.json" ]; then
    spinner_start "Installing frontend dependencies..."
    cd "$FRONTEND_DIR"
    if command -v pnpm &>/dev/null; then
      pnpm install 2>/dev/null || true
    elif command -v npm &>/dev/null; then
      npm install 2>/dev/null || true
    fi
    spinner_stop
    step_ok "Frontend dependencies installed"
    cd "$HARBINGER_DIR"
  else
    step_warn "No frontend package.json found"
  fi

  # 3. Docker check
  if command -v docker &>/dev/null; then
    if docker info &>/dev/null; then
      step_ok "Docker is running"

      # Offer to start services
      echo -e "  ${DIM}│${NC}"
      echo -ne "  ${CYAN}│${NC}  Start services now? ${DIM}[Y/n]${NC} "
      local answer
      read -r answer
      if [[ -z "$answer" || "$answer" =~ ^[Yy] ]]; then
        spinner_start "Starting Docker services..."
        dc up -d 2>/dev/null
        spinner_stop
        step_ok "Services started"
      else
        step_info "Skipped — run ${BOLD}./harbinger start${NC} when ready"
      fi
    else
      step_warn "Docker is installed but not running — start Docker first"
    fi
  else
    step_err "Docker not found — install Docker to run Harbinger services"
  fi

  phase_end

  info "Quick start:"
  echo -e "    ${DIM}→ ./harbinger start     Launch all services${NC}"
  echo -e "    ${DIM}→ ./harbinger dev       Start frontend dev server${NC}"
  echo -e "    ${DIM}→ ./harbinger doctor    Check everything is working${NC}"
  echo ""
}

# ── NUKE ────────────────────────────────────────────────────────────────────
cmd_nuke() {
  banner

  echo -e "  ${RED}${BOLD}⚠  DANGER ZONE${NC}"
  echo ""
  echo -e "  This will ${RED}destroy${NC} all Docker volumes, containers, and node_modules."
  echo -e "  ${RED}All database data will be permanently lost.${NC}"
  echo ""
  echo -ne "  Type ${RED}${BOLD}NUKE${NC} to confirm: "
  local confirm
  read -r confirm
  if [ "$confirm" != "NUKE" ]; then
    echo ""
    info "Aborted."
    return
  fi

  echo ""
  timer_start
  phase_start "Nuking Everything"

  cd "$HARBINGER_DIR"

  spinner_start "Stopping all services..."
  dc down -v --remove-orphans 2>/dev/null || true
  spinner_stop
  step_ok "Services stopped and volumes removed"

  spinner_start "Removing node_modules..."
  rm -rf "$FRONTEND_DIR/node_modules" 2>/dev/null || true
  spinner_stop
  step_ok "node_modules removed"

  spinner_start "Pruning Docker..."
  docker system prune -f 2>/dev/null || true
  spinner_stop
  step_ok "Docker pruned"

  phase_end

  info "Run ${BOLD}./harbinger rebuild${NC} to start fresh."
  echo ""
}

# ── HELP ────────────────────────────────────────────────────────────────────
cmd_help() {
  banner
  echo -e "  ${BOLD}Usage:${NC} ./harbinger ${DIM}[command] [options]${NC}"
  echo -e "  ${DIM}Run with no arguments for interactive wizard mode.${NC}"
  echo ""
  echo -e "  ${CYAN}${BOLD}Core Commands${NC}"
  echo -e "    ${BOLD}update${NC}            Pull latest code + install dependencies"
  echo -e "    ${BOLD}status${NC}            Show service health and versions"
  echo -e "    ${BOLD}doctor${NC}            Diagnose common issues"
  echo -e "    ${BOLD}init${NC}              First-time project setup"
  echo ""
  echo -e "  ${CYAN}${BOLD}Service Management${NC}"
  echo -e "    ${BOLD}start${NC}             Start all Docker services"
  echo -e "    ${BOLD}stop${NC}              Stop all Docker services"
  echo -e "    ${BOLD}restart${NC}           Smart restart (skips missing build contexts)"
  echo -e "    ${BOLD}dev${NC}               Start frontend dev server (Vite)"
  echo -e "    ${BOLD}logs${NC} ${DIM}[service]${NC}    Tail logs (all or specific service)"
  echo ""
  echo -e "  ${CYAN}${BOLD}Maintenance${NC}"
  echo -e "    ${BOLD}rebuild${NC}           Full rebuild (pull + build images + restart)"
  echo -e "    ${BOLD}nuke${NC}              Destroy everything and start fresh"
  echo ""
  echo -e "  ${DIM}Examples:${NC}"
  echo -e "    ${DIM}./harbinger                  # Interactive wizard${NC}"
  echo -e "    ${DIM}./harbinger update            # Pull latest fixes${NC}"
  echo -e "    ${DIM}./harbinger restart           # Smart restart${NC}"
  echo -e "    ${DIM}./harbinger logs postgres     # Debug Postgres issues${NC}"
  echo -e "    ${DIM}./harbinger doctor            # Check what's broken${NC}"
  echo ""
}

# ── COMMAND ROUTER ──────────────────────────────────────────────────────────
run_command() {
  local cmd="$1"
  shift 2>/dev/null || true

  case "$cmd" in
    update)   cmd_update ;;
    status)   cmd_status ;;
    start)    cmd_start ;;
    stop)     cmd_stop ;;
    restart)  cmd_restart ;;
    dev)      cmd_dev ;;
    logs)     cmd_logs "$@" ;;
    rebuild)  cmd_rebuild ;;
    doctor)   cmd_doctor ;;
    init)     cmd_init ;;
    nuke)     cmd_nuke ;;
    help|-h|--help) cmd_help ;;
    *)
      err "Unknown command: $cmd"
      echo ""
      cmd_help
      exit 1
      ;;
  esac
}

# ── MAIN ────────────────────────────────────────────────────────────────────
main() {
  local cmd="${1:-}"

  if [ -z "$cmd" ]; then
    # No args — launch interactive wizard
    wizard
  else
    shift
    run_command "$cmd" "$@"
  fi
}

main "$@"
