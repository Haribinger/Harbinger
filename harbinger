#!/usr/bin/env bash
# ============================================================================
#  HARBINGER CLI — Update, manage, and control your Harbinger instance
#  Usage: ./harbinger <command> [options]
# ============================================================================

set -euo pipefail

# Colors
CYAN='\033[0;36m'
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

HARBINGER_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FRONTEND_DIR="$HARBINGER_DIR/harbinger-tools/frontend"
BACKEND_DIR="$HARBINGER_DIR/backend"

banner() {
  echo -e "${CYAN}"
  echo "  ╔═══════════════════════════════════════════════╗"
  echo "  ║   ██╗  ██╗ █████╗ ██████╗ ██████╗            ║"
  echo "  ║   ██║  ██║██╔══██╗██╔══██╗██╔══██╗           ║"
  echo "  ║   ███████║███████║██████╔╝██████╔╝           ║"
  echo "  ║   ██╔══██║██╔══██║██╔══██╗██╔══██╗           ║"
  echo "  ║   ██║  ██║██║  ██║██║  ██║██████╔╝           ║"
  echo "  ║   ╚═╝  ╚═╝╚═╝  ╚═╝╚═╝  ╚═╝╚═════╝           ║"
  echo "  ║          H A R B I N G E R  CLI               ║"
  echo "  ╚═══════════════════════════════════════════════╝"
  echo -e "${NC}"
}

log()   { echo -e "${GREEN}[✓]${NC} $*"; }
warn()  { echo -e "${YELLOW}[!]${NC} $*"; }
err()   { echo -e "${RED}[✗]${NC} $*"; }
info()  { echo -e "${CYAN}[→]${NC} $*"; }
dim()   { echo -e "${DIM}    $*${NC}"; }

# ── UPDATE ──────────────────────────────────────────────────────────────────
cmd_update() {
  banner
  info "Updating Harbinger..."
  echo ""

  # 1. Git pull
  info "Pulling latest from GitHub..."
  cd "$HARBINGER_DIR"
  git fetch origin main 2>/dev/null

  LOCAL=$(git rev-parse HEAD)
  REMOTE=$(git rev-parse origin/main)

  if [ "$LOCAL" = "$REMOTE" ]; then
    log "Already up to date."
  else
    BEHIND=$(git rev-list --count HEAD..origin/main)
    info "You are ${BEHIND} commit(s) behind. Pulling..."
    git pull origin main --ff-only || {
      warn "Fast-forward failed. Trying rebase..."
      git pull origin main --rebase
    }
    log "Code updated."

    # Show what changed
    echo ""
    info "Recent changes:"
    git log --oneline "$LOCAL"..HEAD | head -10 | while read -r line; do
      dim "$line"
    done
  fi

  echo ""

  # 2. Frontend dependencies
  if [ -f "$FRONTEND_DIR/package.json" ]; then
    info "Checking frontend dependencies..."
    cd "$FRONTEND_DIR"
    if command -v pnpm &>/dev/null; then
      pnpm install --frozen-lockfile 2>/dev/null || pnpm install 2>/dev/null
      log "Frontend dependencies synced (pnpm)."
    elif command -v npm &>/dev/null; then
      npm install 2>/dev/null
      log "Frontend dependencies synced (npm)."
    else
      warn "No package manager found. Install pnpm: npm i -g pnpm"
    fi
  fi

  echo ""
  log "Update complete!"
  echo ""
  info "Next steps:"
  dim "→ ./harbinger restart    Restart all Docker services"
  dim "→ ./harbinger dev        Start frontend dev server"
  dim "→ ./harbinger status     Check service health"
}

# ── STATUS ──────────────────────────────────────────────────────────────────
cmd_status() {
  banner
  info "Harbinger Service Status"
  echo ""

  cd "$HARBINGER_DIR"

  # Git status
  BRANCH=$(git branch --show-current 2>/dev/null || echo "unknown")
  COMMIT=$(git log --oneline -1 2>/dev/null || echo "unknown")
  info "Branch: ${BOLD}${BRANCH}${NC}"
  dim "$COMMIT"
  echo ""

  # Docker services
  if command -v docker &>/dev/null; then
    info "Docker Services:"
    if docker compose ps --format "table {{.Name}}\t{{.Status}}\t{{.Ports}}" 2>/dev/null; then
      :
    elif docker-compose ps 2>/dev/null; then
      :
    else
      warn "Docker Compose not running or not installed."
    fi
  else
    warn "Docker not found."
  fi

  echo ""

  # Frontend dev server
  if lsof -i :3000 &>/dev/null 2>&1 || ss -tlnp 2>/dev/null | grep -q ':3000'; then
    log "Frontend dev server: ${GREEN}RUNNING${NC} on port 3000"
  else
    dim "Frontend dev server: not running"
  fi

  # Backend
  if lsof -i :8080 &>/dev/null 2>&1 || ss -tlnp 2>/dev/null | grep -q ':8080'; then
    log "Backend API: ${GREEN}RUNNING${NC} on port 8080"
  else
    dim "Backend API: not running"
  fi

  # Neo4j
  if lsof -i :7474 &>/dev/null 2>&1 || ss -tlnp 2>/dev/null | grep -q ':7474'; then
    log "Neo4j: ${GREEN}RUNNING${NC} on port 7474"
  else
    dim "Neo4j: not running"
  fi

  # Redis
  if lsof -i :6379 &>/dev/null 2>&1 || ss -tlnp 2>/dev/null | grep -q ':6379'; then
    log "Redis: ${GREEN}RUNNING${NC} on port 6379"
  else
    dim "Redis: not running"
  fi

  # Postgres
  if lsof -i :5432 &>/dev/null 2>&1 || ss -tlnp 2>/dev/null | grep -q ':5432'; then
    log "PostgreSQL: ${GREEN}RUNNING${NC} on port 5432"
  else
    dim "PostgreSQL: not running"
  fi

  echo ""
}

# ── START / STOP / RESTART DOCKER ───────────────────────────────────────────
cmd_start() {
  banner
  info "Starting Harbinger services..."
  cd "$HARBINGER_DIR"
  docker compose up -d 2>/dev/null || docker-compose up -d
  log "Services started."
  echo ""
  cmd_status
}

cmd_stop() {
  banner
  info "Stopping Harbinger services..."
  cd "$HARBINGER_DIR"
  docker compose down 2>/dev/null || docker-compose down
  log "Services stopped."
}

cmd_restart() {
  banner
  info "Restarting Harbinger services..."
  cd "$HARBINGER_DIR"
  docker compose down 2>/dev/null || docker-compose down
  docker compose up -d 2>/dev/null || docker-compose up -d
  log "Services restarted."
  echo ""
  sleep 3
  cmd_status
}

# ── DEV MODE ────────────────────────────────────────────────────────────────
cmd_dev() {
  banner
  info "Starting frontend dev server..."
  cd "$FRONTEND_DIR"
  if command -v pnpm &>/dev/null; then
    pnpm dev
  elif command -v npm &>/dev/null; then
    npm run dev
  else
    err "No package manager found."
    exit 1
  fi
}

# ── LOGS ────────────────────────────────────────────────────────────────────
cmd_logs() {
  local service="${1:-}"
  cd "$HARBINGER_DIR"
  if [ -n "$service" ]; then
    info "Logs for ${BOLD}${service}${NC}:"
    docker compose logs -f --tail=100 "$service" 2>/dev/null || docker-compose logs -f --tail=100 "$service"
  else
    info "Logs for all services (last 50 lines each):"
    docker compose logs -f --tail=50 2>/dev/null || docker-compose logs -f --tail=50
  fi
}

# ── REBUILD ─────────────────────────────────────────────────────────────────
cmd_rebuild() {
  banner
  info "Rebuilding Harbinger from scratch..."
  cd "$HARBINGER_DIR"

  info "Pulling latest code..."
  git pull origin main --ff-only 2>/dev/null || git pull origin main --rebase

  info "Rebuilding Docker images..."
  docker compose build --no-cache 2>/dev/null || docker-compose build --no-cache

  info "Restarting services..."
  docker compose down 2>/dev/null || docker-compose down
  docker compose up -d 2>/dev/null || docker-compose up -d

  echo ""
  info "Installing frontend dependencies..."
  cd "$FRONTEND_DIR"
  if command -v pnpm &>/dev/null; then
    pnpm install
  elif command -v npm &>/dev/null; then
    npm install
  fi

  echo ""
  log "Full rebuild complete!"
  sleep 3
  cmd_status
}

# ── DOCTOR (diagnose issues) ───────────────────────────────────────────────
cmd_doctor() {
  banner
  info "Running Harbinger diagnostics..."
  echo ""

  # Check prerequisites
  local issues=0

  info "Checking prerequisites..."

  if command -v git &>/dev/null; then
    log "git: $(git --version)"
  else
    err "git: NOT FOUND"
    ((issues++))
  fi

  if command -v docker &>/dev/null; then
    log "docker: $(docker --version 2>/dev/null | head -1)"
  else
    err "docker: NOT FOUND"
    ((issues++))
  fi

  if command -v node &>/dev/null; then
    log "node: $(node --version)"
  else
    err "node: NOT FOUND"
    ((issues++))
  fi

  if command -v pnpm &>/dev/null; then
    log "pnpm: $(pnpm --version)"
  elif command -v npm &>/dev/null; then
    warn "pnpm: not found (using npm $(npm --version) as fallback)"
  else
    err "No package manager found"
    ((issues++))
  fi

  echo ""

  # Check .env
  if [ -f "$HARBINGER_DIR/.env" ]; then
    log ".env file exists"
  elif [ -f "$HARBINGER_DIR/.env.example" ]; then
    warn ".env file missing — copying from .env.example"
    cp "$HARBINGER_DIR/.env.example" "$HARBINGER_DIR/.env"
    log ".env created from example. Edit it with your keys."
  else
    err ".env file missing and no .env.example found"
    ((issues++))
  fi

  echo ""

  # Check Docker services health
  info "Checking Docker service health..."
  cd "$HARBINGER_DIR"

  for svc in postgres redis neo4j; do
    if docker compose ps "$svc" 2>/dev/null | grep -q "Up"; then
      log "$svc: healthy"
    elif docker compose ps "$svc" 2>/dev/null | grep -qi "restart"; then
      err "$svc: RESTARTING — check logs with: ./harbinger logs $svc"
      ((issues++))
    else
      warn "$svc: not running"
    fi
  done

  echo ""

  # Check for common frontend issues
  info "Checking frontend..."
  if [ -d "$FRONTEND_DIR/node_modules" ]; then
    log "node_modules exists"
  else
    warn "node_modules missing — run: ./harbinger update"
    ((issues++))
  fi

  if [ -f "$FRONTEND_DIR/src/store/secretsStore.ts" ]; then
    log "secretsStore.ts exists"
  else
    err "secretsStore.ts MISSING — this will cause a white screen!"
    ((issues++))
  fi

  echo ""

  if [ "$issues" -eq 0 ]; then
    log "${GREEN}${BOLD}All checks passed! Harbinger is healthy.${NC}"
  else
    warn "${YELLOW}Found ${issues} issue(s). Fix them and run ./harbinger doctor again.${NC}"
  fi
  echo ""
}

# ── NUKE (clean reset) ─────────────────────────────────────────────────────
cmd_nuke() {
  banner
  warn "This will destroy all Docker volumes, containers, and node_modules."
  echo -e "  ${RED}All database data will be lost.${NC}"
  echo ""
  read -rp "  Type 'NUKE' to confirm: " confirm
  if [ "$confirm" != "NUKE" ]; then
    info "Aborted."
    return
  fi

  cd "$HARBINGER_DIR"
  info "Stopping all services..."
  docker compose down -v --remove-orphans 2>/dev/null || docker-compose down -v --remove-orphans

  info "Removing node_modules..."
  rm -rf "$FRONTEND_DIR/node_modules" 2>/dev/null

  info "Pruning Docker..."
  docker system prune -f 2>/dev/null

  echo ""
  log "Nuked. Run ./harbinger rebuild to start fresh."
}

# ── HELP ────────────────────────────────────────────────────────────────────
cmd_help() {
  banner
  echo -e "  ${BOLD}Usage:${NC} ./harbinger <command> [options]"
  echo ""
  echo -e "  ${CYAN}${BOLD}Core Commands:${NC}"
  echo -e "    ${BOLD}update${NC}          Pull latest code + install dependencies"
  echo -e "    ${BOLD}status${NC}          Show service health and versions"
  echo -e "    ${BOLD}doctor${NC}          Diagnose common issues"
  echo ""
  echo -e "  ${CYAN}${BOLD}Service Management:${NC}"
  echo -e "    ${BOLD}start${NC}           Start all Docker services"
  echo -e "    ${BOLD}stop${NC}            Stop all Docker services"
  echo -e "    ${BOLD}restart${NC}         Restart all Docker services"
  echo -e "    ${BOLD}dev${NC}             Start frontend dev server (Vite)"
  echo -e "    ${BOLD}logs${NC} [service]  Tail logs (all or specific service)"
  echo ""
  echo -e "  ${CYAN}${BOLD}Maintenance:${NC}"
  echo -e "    ${BOLD}rebuild${NC}         Full rebuild (pull + build images + restart)"
  echo -e "    ${BOLD}nuke${NC}            Destroy everything and start fresh"
  echo ""
  echo -e "  ${DIM}Examples:${NC}"
  dim "./harbinger update          # Pull latest fixes"
  dim "./harbinger restart         # Restart after update"
  dim "./harbinger logs postgres   # Debug Postgres issues"
  dim "./harbinger doctor          # Check what's broken"
  echo ""
}

# ── MAIN ROUTER ─────────────────────────────────────────────────────────────
main() {
  local cmd="${1:-help}"
  shift 2>/dev/null || true

  case "$cmd" in
    update)   cmd_update ;;
    status)   cmd_status ;;
    start)    cmd_start ;;
    stop)     cmd_stop ;;
    restart)  cmd_restart ;;
    dev)      cmd_dev ;;
    logs)     cmd_logs "$@" ;;
    rebuild)  cmd_rebuild ;;
    doctor)   cmd_doctor ;;
    nuke)     cmd_nuke ;;
    help|-h|--help) cmd_help ;;
    *)
      err "Unknown command: $cmd"
      echo ""
      cmd_help
      exit 1
      ;;
  esac
}

main "$@"
