#!/usr/bin/env bash
# ============================================================================
#  HARBINGER CLI v2 — Wizard-style interactive command center
#  Usage: ./harbinger [command] [options]
#  Run with no args for interactive wizard mode.
# ============================================================================

set -euo pipefail

# ── COLORS & STYLES ─────────────────────────────────────────────────────────
CYAN='\033[38;5;45m'
GREEN='\033[38;5;82m'
RED='\033[38;5;196m'
YELLOW='\033[38;5;220m'
DIM='\033[2m'
BOLD='\033[1m'
ITALIC='\033[3m'
NC='\033[0m'
WHITE='\033[1;37m'

# ── PATHS ───────────────────────────────────────────────────────────────────
HARBINGER_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FRONTEND_DIR="$HARBINGER_DIR/harbinger-tools/frontend"
BACKEND_DIR="$HARBINGER_DIR/backend"
MCP_DIR="$HARBINGER_DIR/mcp-plugins"

# ── SPINNER ─────────────────────────────────────────────────────────────────
SPINNER_FRAMES=("⠋" "⠙" "⠹" "⠸" "⠼" "⠴" "⠦" "⠧" "⠇" "⠏")
SPINNER_PID=""

spinner_start() {
  local msg="${1:-Working...}"
  (
    local i=0
    while true; do
      printf "\r  ${CYAN}${SPINNER_FRAMES[$i]}${NC} %s" "$msg"
      i=$(( (i + 1) % ${#SPINNER_FRAMES[@]} ))
      sleep 0.08
    done
  ) &
  SPINNER_PID=$!
  disown "$SPINNER_PID" 2>/dev/null
}

spinner_stop() {
  if [ -n "$SPINNER_PID" ] && kill -0 "$SPINNER_PID" 2>/dev/null; then
    kill "$SPINNER_PID" 2>/dev/null
    wait "$SPINNER_PID" 2>/dev/null || true
  fi
  SPINNER_PID=""
  printf "\r\033[K"
}

# ── TIMING ──────────────────────────────────────────────────────────────────
TASK_START=""

timer_start() {
  TASK_START=$(date +%s%N 2>/dev/null || date +%s)
}

timer_elapsed() {
  local now
  now=$(date +%s%N 2>/dev/null || date +%s)
  if [ ${#TASK_START} -gt 10 ] && [ ${#now} -gt 10 ]; then
    local diff=$(( (now - TASK_START) / 1000000 ))
    local secs=$(( diff / 1000 ))
    local ms=$(( diff % 1000 ))
    printf "%d.%01ds" "$secs" "$(( ms / 100 ))"
  else
    local diff=$(( now - TASK_START ))
    printf "%ds" "$diff"
  fi
}

# ── PROGRESS LOGGING ────────────────────────────────────────────────────────
step_ok()   { echo -e "  ${GREEN}├${NC} ${GREEN}✓${NC} $*"; }
step_warn() { echo -e "  ${YELLOW}├${NC} ${YELLOW}⚠${NC} $*"; }
step_err()  { echo -e "  ${RED}├${NC} ${RED}✗${NC} $*"; }
step_info() { echo -e "  ${CYAN}├${NC} ${CYAN}◌${NC} $*"; }
step_run()  { echo -e "  ${DIM}├${NC} ${DIM}$*${NC}"; }

phase_start() { echo -e "  ${CYAN}◆${NC} ${BOLD}$*${NC}"; echo -e "  ${DIM}│${NC}"; }
phase_end()   { echo -e "  ${DIM}│${NC}"; echo -e "  ${GREEN}└${NC} ${GREEN}Done${NC}${DIM} in $(timer_elapsed)${NC}"; echo ""; }

log()   { echo -e "  ${GREEN}[✓]${NC} $*"; }
warn()  { echo -e "  ${YELLOW}[!]${NC} $*"; }
err()   { echo -e "  ${RED}[✗]${NC} $*"; }
info()  { echo -e "  ${CYAN}[→]${NC} $*"; }

# ── BANNER ──────────────────────────────────────────────────────────────────
banner() {
  echo ""
  echo -e "${CYAN}${BOLD}"
  echo "    ██╗  ██╗ █████╗ ██████╗ ██████╗ ██╗███╗   ██╗ ██████╗ ███████╗██████╗ "
  echo "    ██║  ██║██╔══██╗██╔══██╗██╔══██╗██║████╗  ██║██╔════╝ ██╔════╝██╔══██╗"
  echo "    ███████║███████║██████╔╝██████╔╝██║██╔██╗ ██║██║  ███╗█████╗  ██████╔╝"
  echo "    ██╔══██║██╔══██║██╔══██╗██╔══██╗██║██║╚██╗██║██║   ██║██╔══╝  ██╔══██╗"
  echo "    ██║  ██║██║  ██║██║  ██║██████╔╝██║██║ ╚████║╚██████╔╝███████╗██║  ██║"
  echo "    ╚═╝  ╚═╝╚═╝  ╚═╝╚═╝  ╚═╝╚═════╝ ╚═╝╚═╝  ╚═══╝ ╚═════╝ ╚══════╝╚═╝  ╚═╝"
  echo -e "${NC}"
  echo -e "    ${DIM}Command Center${NC}  ${DIM}·${NC}  ${DIM}v2.0${NC}"
