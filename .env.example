# Harbinger Configuration
# Copy to .env and fill in ALL required values before running docker compose up.
# NEVER commit the actual .env file with real secrets!
#
# Generate secrets:
#   openssl rand -base64 32    (for AUTH_SECRET)
#   openssl rand -hex 32       (for JWT_SECRET, webhook secrets)
#   openssl rand -hex 16       (for passwords)

# ============================================================
# REQUIRED — docker compose will refuse to start without these
# ============================================================

# Database credentials
DB_PASSWORD=
JWT_SECRET=
NEO4J_PASSWORD=
REDIS_PASSWORD=

# ROAR inter-agent message bus authentication
ROAR_SECRET=

# Auth.js session encryption secret
AUTH_SECRET=

# ============================================================
# Application Settings
# ============================================================

APP_NAME=Harbinger
APP_ENV=production
APP_PORT=8080
APP_URL=https://your-domain.com

# Trust the host header when behind a reverse proxy
AUTH_TRUST_HOST=true

# Database (non-secret config)
DB_NAME=harbinger
DB_USER=harbinger

# ============================================================
# Optional Integrations
# ============================================================

# GitHub Personal Access Token (needs repo, workflow scopes)
GH_TOKEN=
GH_OWNER=
GH_REPO=

# GitHub OAuth App (create at https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Telegram bot (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_VERIFICATION=
TELEGRAM_CHAT_ID=

# GitHub Actions webhook auth
GH_WEBHOOK_SECRET=

# LLM provider config
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# LLM_PROVIDER=anthropic
# LLM_MODEL=

# ============================================================
# Docker / Infrastructure
# ============================================================

# Docker network name — must match the compose network for spawned agent containers
DOCKER_NETWORK=harbinger_harbinger-network

# Nginx ports
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Frontend port (internal, behind nginx)
FRONTEND_PORT=3000

# Service tool paths (for hexstrike)
# NIKTO_PATH=/usr/bin/nikto
# NUCLEI_PATH=/usr/local/bin/nuclei

# ============================================================
# Optional overrides (defaults are fine for most setups)
# ============================================================
# APP_VERSION=1.1.0
# LOG_LEVEL=info
# MCP_ENABLED=true
# BROWSER_SERVICE_URL=
# GITHUB_REDIRECT_URL=
