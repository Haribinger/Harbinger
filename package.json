{
  "name": "harbinger",
  "version": "1.0.0",
  "type": "module",
  "description": "Harbinger - Professional Bug Bounty Hunting Platform with autonomous AI agents, 150+ security tools, and real-time visualization",
  "keywords": [
    "bug-bounty",
    "security",
    "pentest",
    "ai-agents",
    "mcp",
    "autonomous"
  ],
  "license": "MIT",
  "bin": {
    "harbinger": "./bin/cli.js"
  },
  "exports": {
    "./api": "./api/index.js",
    "./config": "./config/index.js",
    "./instrumentation": "./config/instrumentation.js",
    "./auth": "./lib/auth/index.js",
    "./auth/actions": "./lib/auth/actions.js",
    "./chat": "./lib/chat/components/index.js",
    "./chat/actions": "./lib/chat/actions.js",
    "./chat/api": "./lib/chat/api.js",
    "./db": "./lib/db/index.js",
    "./middleware": "./lib/auth/middleware.js"
  },
  "scripts": {
    "dev": "pnpm --filter harbinger-frontend dev",
    "dev:nextjs": "next dev --turbopack",
    "dev:stable": "next dev",
    "dev:all": "concurrently \"pnpm dev:nextjs\" \"pnpm dev\"",
    "doctor": "node scripts/doctor.js",
    "reset": "rm -rf .next frontend/dist frontend/node_modules/.vite",
    "packageManager": "pnpm@10.30.2",
    "preinstall": "node scripts/preinstall.cjs",
    "build": "NODE_OPTIONS='--max_old_space_size=8192' next build",
    "build:ui": "pnpm --filter harbinger-frontend build",
    "start": "next start",
    "setup": "node bin/cli.js setup",
    "setup-platform": "node bin/cli.js setup-platform",
    "setup-telegram": "node bin/cli.js setup-telegram",
    "setup-discord": "node bin/cli.js setup-discord",
    "reset-auth": "node bin/cli.js reset-auth",
    "status": "node bin/cli.js status",
    "agents": "node bin/cli.js agents",
    "agents:templates": "node bin/cli.js agents:templates",
    "agents:spawn": "node bin/cli.js agents:spawn",
    "agents:create": "node bin/cli.js agents:create",
    "channels": "node bin/cli.js channels",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@ai-sdk/react": "^2.0.0",
    "@clack/prompts": "^0.9.1",
    "@grammyjs/parse-mode": "^2.2.1",
    "@langchain/anthropic": "0.3.13",
    "@langchain/core": "^0.3.0",
    "@langchain/google-genai": "^0.1.0",
    "@langchain/langgraph": "^0.2.0",
    "@langchain/langgraph-checkpoint": "^0.1.1",
    "@langchain/langgraph-checkpoint-sqlite": "^0.2.1",
    "@langchain/openai": "^0.3.0",
    "@octokit/rest": "^20.0.0",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@tailwindcss/postcss": "^4.0.0",
    "@tanstack/react-query": "^5.24.0",
    "@xterm/xterm": "^5.5.0",
    "ai": "^5.0.0",
    "axios": "^1.15.2",
    "bcrypt-ts": "^6.0.0",
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.3.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.3.1",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.44.0",
    "framer-motion": "^11.0.8",
    "grammy": "^1.40.0",
    "lucide-react": "^0.400.0",
    "next": "^15.5.14",
    "next-auth": "5.0.0-beta.30",
    "next-themes": "^0.4.0",
    "node-cron": "^4.2.1",
    "open": "^9.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.22.0",
    "reactflow": "^11.10.4",
    "recharts": "^2.12.0",
    "remark-gfm": "^4.0.0",
    "socket.io-client": "^4.7.4",
    "streamdown": "^2.3.0",
    "tailwind-merge": "^2.2.1",
    "tailwindcss": "^4.0.0",
    "uuid": "^9.0.1",
    "zod": "^3.23.0",
    "zustand": "^4.5.0"
  },
  "overrides": {
    "langsmith": "^0.4.6",
    "minimatch": "^10.2.1",
    "fast-xml-parser": "^5.3.7"
  },
  "devDependencies": {
    "@eslint/js": "^8",
    "@types/node": "^20.11.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^8.0.0",
    "drizzle-kit": "^0.31.9",
    "esbuild": "^0.27.4",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.3.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.56.1"
  }
}